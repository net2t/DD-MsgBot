# ============================================================================
# DD-Msg-Bot V2 — Environment Variables
# Copy this file to .env and fill in your real values.
# IMPORTANT: Never commit your real .env to Git.
# ============================================================================

# ── DamaDam Login (Primary) ──────────────────────────────────────────────────
# DD_LOGIN_EMAIL = your DamaDam username/nick (NOT your email address)
DD_LOGIN_EMAIL=
DD_LOGIN_PASS=

# ── DamaDam Login (Backup — optional) ────────────────────────────────────────
# If primary login fails, the bot tries these credentials automatically.
DD_LOGIN_EMAIL2=
DD_LOGIN_PASS2=

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Sheet ID from the URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
DD_SHEET_ID=

# Path to your Google service account JSON key file
CREDENTIALS_FILE=credentials.json

# ── Browser / Selenium ────────────────────────────────────────────────────────
# 1 = headless (no browser window, required for GitHub Actions)
# 0 = visible browser window (useful for local debugging)
DD_HEADLESS=1

# ChromeDriver path (leave empty to use system PATH)
CHROMEDRIVER_PATH=

# Page load timeout in seconds
DD_PAGE_LOAD_TIMEOUT=15

# ── Debug ─────────────────────────────────────────────────────────────────────
# 1 = verbose debug logs, 0 = normal
DD_DEBUG=0

# ── Message Mode ──────────────────────────────────────────────────────────────
# How many profile post pages to scan to find an open post
DD_MAX_POST_PAGES=4

# Delay between each message send (seconds)
DD_MSG_DELAY_SECONDS=3

# ── Post Mode ─────────────────────────────────────────────────────────────────
# Hard cooldown between posts — DamaDam enforces ~2min 10sec minimum
DD_POST_COOLDOWN_SECONDS=135

# Maximum caption length (characters)
DD_POST_CAPTION_MAX_LEN=300

# Maximum tags length (characters)
DD_POST_TAGS_MAX_LEN=120

# Collapse repeated characters: "hhhhhhhhhh" → "hhhhhh" when set to 6
DD_POST_MAX_REPEAT_CHARS=6

# Text appended to every post caption (e.g. a signature emoji).
# Leave empty to disable.
DD_POST_SIGNATURE=

# ── Rekhta Mode ───────────────────────────────────────────────────────────────
# Rekhta shayari image listing page URL
DD_REKHTA_URL=https://www.rekhta.org/shayari-image

# Number of scroll actions on the Rekhta page (more scrolls = more cards loaded)
DD_REKHTA_MAX_SCROLLS=6

# ── Image Download ────────────────────────────────────────────────────────────
# Timeout for each image download attempt (seconds)
DD_IMAGE_DOWNLOAD_TIMEOUT=90

# Number of retry attempts if a download fails
DD_IMAGE_DOWNLOAD_RETRIES=3
