# DD-Msg-Bot V4.1.0 Environment Configuration
# Copy this file to .env and fill in your actual values

# ── DamaDam Credentials (REQUIRED) ─────────────────────────────────────
DD_LOGIN_EMAIL=your_damadam_username
DD_LOGIN_PASS=your_damadam_password

# ── Backup Account (Optional) ───────────────────────────────────────────
DD_LOGIN_EMAIL2=backup_damadam_username
DD_LOGIN_PASS2=backup_damadam_password

# ── Google Sheets Configuration (REQUIRED) ─────────────────────────────
DD_SHEET_ID=your_google_sheet_id_here
GOOGLE_CREDENTIALS_JSON=your_full_google_credentials_json_here

# Alternative: Use credentials file instead of JSON string
CREDENTIALS_FILE=credentials.json

# ── Browser Settings ─────────────────────────────────────────────────────
DD_HEADLESS=1
DD_DISABLE_IMAGES=1
DD_PAGE_LOAD_TIMEOUT=60

# ── Chrome Driver (Optional) ─────────────────────────────────────────────
# CHROMEDRIVER_PATH=path/to/chromedriver.exe

# ── Message Settings ────────────────────────────────────────────────────
DD_MSG_DELAY_SECONDS=3

# ── Debug & Development ─────────────────────────────────────────────────
DD_DEBUG=0
DD_DRY_RUN=0

# ── Performance Settings ─────────────────────────────────────────────────
DD_MAX_PROFILES=0
